# HTTP server
PORT=3000
# 127.0.0.1 = only reachable from this machine (SSH tunnel / your own reverse
# proxy in front). Set to 0.0.0.0 to expose the panel directly to the internet.
PANEL_HOST=127.0.0.1

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h

# SQLite database file
DB_PATH=./data/ssmanager.db

# Initial admin account, used only by `npm run seed` when the users table is empty
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Default ssmanager --manager-addr the panel talks to (can be changed later in Settings)
MANAGER_HOST=127.0.0.1
MANAGER_PORT=6100

# Default ssmanager binary launch config (used by the process supervisor / Settings)
SSMANAGER_BIN=ssmanager
SSMANAGER_ARGS=--manager-addr 127.0.0.1:6100 -s 0.0.0.0 -m aes-256-gcm
